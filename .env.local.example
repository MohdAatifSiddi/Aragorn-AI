/**
 * Environment Variables Template
 * 
 * This file serves as a template for required environment variables.
 * Copy this file to .env.local and fill in your actual values.
 * 
 * Setup Instructions:
 * 1. Copy this file: cp .env.local.example .env.local
 * 2. Fill in all values with your actual credentials
 * 3. Never commit .env.local to Git (it's in .gitignore)
 * 
 * Variable Types:
 * - NEXT_PUBLIC_* variables are exposed to the browser
 * - Other variables are server-only (more secure)
 * 
 * Security Notes:
 * - Keep .env.local private and secure
 * - Never share credentials in public repositories
 * - Use different credentials for development and production
 * - Rotate keys regularly
 * - Use Vercel environment variables for production
 * 
 * @see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
 */

# ============================================
# Supabase Configuration
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
#
# NEXT_PUBLIC_SUPABASE_URL: Your Supabase project URL
# Format: https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Public anonymous key (safe for browser)
# Used for client-side authentication and queries
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# SUPABASE_SERVICE_ROLE_KEY: Private service role key (server-only)
# Has elevated privileges - NEVER expose to browser
# Used for admin operations and edge device ingestion
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# DATABASE_URL: Direct PostgreSQL connection string (optional)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=your_database_url

# NEXT_PUBLIC_SITE_URL: Your application's public URL
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# AWS Configuration
# ============================================
# Get these from: https://console.aws.amazon.com/iam/
#
# AWS_REGION: AWS region for S3 and Rekognition services
# Common values: us-east-1, us-west-2, eu-west-1
# Choose region closest to your users
AWS_REGION=us-east-1

# AWS_ACCESS_KEY_ID: IAM user access key
# Required permissions:
# - s3:PutObject, s3:GetObject (for image storage)
# - rekognition:DetectProtectiveEquipment (for PPE detection)
# - rekognition:DetectLabels (for object detection)
# - rekognition:DetectModerationLabels (for hazard detection)
AWS_ACCESS_KEY_ID=your_aws_access_key_id

# AWS_SECRET_ACCESS_KEY: IAM user secret key (keep secure!)
# Never commit this to Git or expose to browser
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS_S3_BUCKET: S3 bucket name for storing construction site images
# Must be created in AWS console before use
# Recommended: Enable versioning and encryption
# Example: aragorn-construction-images
AWS_S3_BUCKET=aragorn-construction-images
