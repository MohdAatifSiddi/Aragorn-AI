/**
 * Package Configuration
 * 
 * Defines project metadata, dependencies, and scripts for Aragorn AI.
 * 
 * Project Information:
 * - name: "aragorn-ai" - NPM package name
 * - version: "2.0.0" - Current version (semantic versioning)
 * - description: Project description for NPM registry
 * - private: true - Prevents accidental publishing to NPM
 * - author: "Aragorn AI Team"
 * - license: "MIT" - Open source license
 * 
 * Scripts:
 * - dev: Start development server with Turbopack (faster than Webpack)
 * - build: Create production build
 * - start: Start production server
 * - lint: Run ESLint for code quality checks
 * - test:aws: Test AWS connection and credentials
 * - postbuild: Runs automatically after build (success message)
 * - type-check: Check TypeScript types without emitting files
 * - format: Format code with Prettier
 * - clean: Remove build artifacts and caches
 * 
 * Dependencies (Production):
 * 
 * AWS SDK:
 * - @aws-sdk/client-rekognition: AI image analysis (PPE detection)
 * - @aws-sdk/client-s3: S3 storage for images
 * - @aws-sdk/s3-request-presigner: Generate signed URLs
 * - aws-sdk: Legacy SDK v2 (consider migrating to v3)
 * 
 * Supabase (Database & Auth):
 * - @supabase/ssr: Server-side rendering support
 * - @supabase/supabase-js: JavaScript client
 * 
 * UI Components (Radix UI):
 * - 25+ @radix-ui/* packages: Accessible component primitives
 * - Includes: accordion, dialog, dropdown, tabs, tooltip, etc.
 * 
 * Forms & Validation:
 * - react-hook-form: Form state management
 * - @hookform/resolvers: Form validation resolvers
 * - zod: Schema validation
 * 
 * Styling:
 * - tailwind-merge: Merge Tailwind classes intelligently
 * - class-variance-authority: Component variants
 * - clsx: Conditional class names
 * 
 * UI Utilities:
 * - lucide-react: Icon library (1000+ icons)
 * - framer-motion: Animation library
 * - next-themes: Dark mode support
 * - sonner: Toast notifications
 * - date-fns: Date formatting
 * - recharts: Chart library for analytics
 * 
 * Next.js & React:
 * - next: ^15.5.7 - Next.js framework
 * - react: 19.2.0 - React library
 * - react-dom: 19.2.0 - React DOM renderer
 * 
 * CMS Integration:
 * - orchids-visual-edits: Visual editing support
 * 
 * Other:
 * - cmdk: Command palette component
 * - embla-carousel-react: Carousel component
 * - input-otp: OTP input component
 * - react-resizable-panels: Resizable panel layouts
 * - sharp: Image optimization
 * - vaul: Drawer component
 * 
 * Dev Dependencies:
 * - @eslint/eslintrc: ESLint configuration
 * - @tailwindcss/postcss: Tailwind PostCSS plugin
 * - @types/*: TypeScript type definitions
 * - eslint: Code linting
 * - eslint-config-next: Next.js ESLint config
 * - tailwindcss: Utility-first CSS framework
 * - tw-animate-css: Tailwind animation utilities
 * - typescript: TypeScript compiler
 * 
 * Engine Requirements:
 * - node: >=18.0.0 - Requires Node.js 18 or higher
 * - npm: >=9.0.0 - Requires NPM 9 or higher
 * 
 * Keywords:
 * - construction, ai, computer-vision, safety, ppe-detection
 * - aws-rekognition, nextjs, typescript
 * - Used for NPM search and discovery
 * 
 * @see https://docs.npmjs.com/cli/v9/configuring-npm/package-json
 */
{
  "name": "aragorn-ai",
  "version": "2.0.0",
  "description": "Autonomous Construction Intelligence Platform with AWS-powered AI analysis",
  "private": true,
  "author": "Aragorn AI Team",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:aws": "node test-aws-connection.js",
    "postbuild": "echo '✅ Build completed successfully'",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "rm -rf .next out node_modules/.cache"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1000.0",
